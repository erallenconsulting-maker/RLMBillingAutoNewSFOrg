<apex:page controller="QuotePDFController" 
           renderAs="pdf" 
           applyHtmlTag="false" 
           applyBodyTag="false" 
           showHeader="false" 
           sidebar="false"
           cache="false">
<html>
<head>
<style type="text/css">
@page {
    size: letter portrait;
    margin: 0.5in;
    @bottom-center {
        content: "Page " counter(page) " of " counter(pages);
        font-size: 8pt;
        color: #666;
    }
}
body { font-family: Arial, sans-serif; font-size: 9pt; color: #000; }
.header { text-align: center; margin-bottom: 12pt; }
.header h1 { font-size: 18pt; margin: 0; color: #1F3864; }
.header .subtitle { font-size: 10pt; color: #666; margin-top: 2pt; }
table { border-collapse: collapse; width: 100%; margin-bottom: 10pt; }
table.lineitems th, table.lineitems td { border: 0.5pt solid #999; padding: 4pt; text-align: left; vertical-align: top; }
table.lineitems th { background-color: #1F3864; color: white; font-weight: bold; font-size: 8pt; text-align: center; }
table.lineitems td { font-size: 8pt; }
table.lineitems td.num { text-align: right; }
table.lineitems td.center { text-align: center; }
.total-row td { background-color: #E7E6E6; font-weight: bold; }
.special-terms { border: 0.5pt solid #999; padding: 6pt; margin-bottom: 10pt; }
.special-terms .label { background-color: #1F3864; color: white; font-weight: bold; padding: 4pt 6pt; margin: -6pt -6pt 4pt -6pt; }
.three-col { width: 100%; margin-bottom: 10pt; }
.three-col td { border: 0.5pt solid #999; padding: 6pt; vertical-align: top; width: 33%; font-size: 8pt; }
.three-col th { background-color: #1F3864; color: white; padding: 4pt 6pt; font-weight: bold; text-align: left; font-size: 9pt; border: 0.5pt solid #999; width: 33%; }
.legal { font-size: 7pt; color: #333; line-height: 1.3; margin: 8pt 0; }
.signatures { width: 100%; margin-top: 14pt; }
.signatures td { border: 0.5pt solid #999; padding: 8pt; vertical-align: top; font-size: 9pt; height: 18pt; }
.signatures td.label { background-color: #F2F2F2; font-weight: bold; width: 12%; }
.signatures td.field { width: 38%; }
</style>
</head>
<body>

<div class="header">
    <h1>TECHVERA</h1>
    <div class="subtitle">Order Form</div>
</div>

<!-- LINE ITEMS TABLE -->
<table class="lineitems">
    <thead>
        <tr>
            <th style="width:18%">PRODUCT &amp; PLAN DESCRIPTION</th>
            <th style="width:5%">QTY</th>
            <th style="width:9%">UNIT PRICE</th>
            <th style="width:6%">Disc %</th>
            <th style="width:9%">Disc Unit Price</th>
            <th style="width:10%">BILLING FREQUENCY</th>
            <th style="width:7%">Term (Months)</th>
            <th style="width:9%">Start Date</th>
            <th style="width:13%">Net Unit Price (Disc. Unit x Billing Frequency)</th>
            <th style="width:14%">TOTAL (Quantity x Net Unit)</th>
        </tr>
    </thead>
    <tbody>
        <apex:repeat value="{!lineItems}" var="li">
            <tr>
                <td>
                    <strong><apex:outputText value="{!li.Product2.Name}"/></strong><br/>
                    <apex:outputText value="{!IF(NOT(ISBLANK(li.Detailed_Line_Description__c)), li.Detailed_Line_Description__c, IF(NOT(ISBLANK(li.Description)), li.Description, ''))}" escape="false"/>
                </td>
                <td class="num"><apex:outputText value="{0,number,#,##0}"><apex:param value="{!li.Quantity}"/></apex:outputText></td>
                <td class="num"><apex:outputText value="{0,number,$#,##0.00}"><apex:param value="{!li.ListPrice}"/></apex:outputText></td>
                <td class="num"><apex:outputText value="{0,number,#,##0.0}"><apex:param value="{!IF(li.Discount = null, 0, li.Discount)}"/></apex:outputText>%</td>
                <td class="num"><apex:outputText value="{0,number,$#,##0.00}"><apex:param value="{!li.UnitPrice}"/></apex:outputText></td>
                <td class="center"><apex:outputText value="{!li.BillingFrequency__c}"/></td>
                <td class="center"><apex:outputText value="{!li.SubscriptionTerm}"/></td>
                <td class="center"><apex:outputText value="{0,date,MM-dd-yyyy}"><apex:param value="{!li.StartDate}"/></apex:outputText></td>
                <td class="num"><apex:outputText value="{0,number,$#,##0.00}"><apex:param value="{!li.NetUnitPrice}"/></apex:outputText></td>
                <td class="num"><apex:outputText value="{0,number,$#,##0.00}"><apex:param value="{!li.NetTotalPrice}"/></apex:outputText></td>
            </tr>
        </apex:repeat>
        <tr class="total-row">
            <td colspan="8"></td>
            <td class="num">ORDER TOTAL:</td>
            <td class="num"><apex:outputText value="{0,number,$#,##0.00}"><apex:param value="{!q.GrandTotal}"/></apex:outputText></td>
        </tr>
    </tbody>
</table>

<!-- SPECIAL TERMS -->
<div class="special-terms">
    <div class="label">Special Terms</div>
    <apex:outputText value="{!IF(NOT(ISBLANK(q.Special_Terms__c)), q.Special_Terms__c, '')}" escape="false"/>
</div>

<!-- PREPARED FOR / PREPARED BY / DETAILS -->
<table class="three-col">
    <thead>
        <tr>
            <th>Prepared For</th>
            <th>Prepared By</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>
                <strong><apex:outputText value="{!acct.Name}"/></strong><br/>
                <apex:outputText value="{!q.BillingStreet}"/><br/>
                <apex:outputText value="{!q.BillingCity}"/>, <apex:outputText value="{!q.BillingState}"/> <apex:outputText value="{!q.BillingPostalCode}"/><br/>
                <apex:outputText value="{!q.BillingCountry}"/><br/>
                <br/>
                <strong><apex:outputText value="{!billToContact.Name}"/></strong><br/>
                <apex:outputText value="{!billToContact.Email}"/><br/>
                <apex:outputText value="{!billToContact.Phone}"/>
            </td>
            <td>
                <strong><apex:outputText value="{!owner.Name}"/></strong><br/>
                <apex:outputText value="{!owner.Email}"/><br/>
                <apex:outputText value="{!owner.Phone}"/>
            </td>
            <td>
                <strong><apex:outputText value="{!acct.Name}"/></strong><br/>
                Quote #: <apex:outputText value="{!quoteName}"/><br/>
                Delivered: <apex:outputText value="{!today}"/><br/>
                Expires: <apex:outputText value="{!formattedExpirationDate}"/><br/>
                Due Date: <apex:outputText value="{!q.Payment_Terms__c}"/><br/>
                Currency: USD
            </td>
        </tr>
    </tbody>
</table>

<!-- LEGAL TEXT -->
<div class="legal">
This Order Form is subject to and governed by the Techvera LLC Master Services Agreement available online at: <strong>https://techvera.com/services-information-hub/</strong> (MSA), the terms of which MSA are hereby incorporated by reference; provided, however, that if a Master Services Agreement is attached hereto or is separately signed between the parties, this Order Form is subject to and governed by the terms of such MSA, which are hereby incorporated by reference.<br/><br/>
Taxes, shipping, handling and other fees may apply. To ensure uninterrupted service, Client agrees to maintain a valid payment method on file with Techvera. Recurring service invoices will be automatically charged to the payment method on file on or after the invoice due date. We reserve the right to cancel orders arising from pricing or other errors.
</div>

<!-- SIGNATURE BLOCK -->
<table class="signatures">
    <tr>
        <td class="label">Signature:</td>
        <td class="field"></td>
        <td class="label">Signature:</td>
        <td class="field"></td>
    </tr>
    <tr>
        <td class="label">Name:</td>
        <td class="field"></td>
        <td class="label">Name:</td>
        <td class="field"></td>
    </tr>
    <tr>
        <td class="label">Title:</td>
        <td class="field"></td>
        <td class="label">Title:</td>
        <td class="field">Chief Operating Officer</td>
    </tr>
    <tr>
        <td class="label">Date:</td>
        <td class="field"></td>
        <td class="label">Date:</td>
        <td class="field"></td>
    </tr>
</table>

</body>
</html>
</apex:page>
