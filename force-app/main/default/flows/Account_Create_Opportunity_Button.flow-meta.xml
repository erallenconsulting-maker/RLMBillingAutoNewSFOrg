                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetOpenOpp</targetReference>
            </connector>
            <label>Open Opp Exists</label>
        </rules>
        <rules>
            <name>No_Open_Opp</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>GetOpenOpp.Id</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Intro_Screen</targetReference>
            </connector>
            <label>No Open Opp</label>
        </rules>
    </decisions>
