            <conditions>
                <leftValueReference>GetOpenOpp.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>GetOpenOpp.Id</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>GetOpenOpp.StageName</leftValueReference>
                <operator>NotEqualTo</operator>
