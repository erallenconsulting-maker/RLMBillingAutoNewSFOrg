<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Average_Customer_Discount__c</fullName>
    <description>Average customer discount (in percent) for this quote.</description>
    <externalId>false</externalId>
    <formula>IF(List_Amount__c = 0,0,(List_Amount__c - Customer_Amount__c /List_Amount__c))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Average customer discount (in percent) for this quote.</inlineHelpText>
    <label>Avg. Customer Disc. (%)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <type>Percent</type>
</CustomField>
